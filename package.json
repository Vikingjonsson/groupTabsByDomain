{
  "name": "group-tabs-by-domain",
  "version": "1.0.0",
  "description": "Chrome extension to automatically group tabs by domain",
  "author": "Viking Jonsson",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "tabs",
    "grouping",
    "domain",
    "productivity"
  ],
  "scripts": {
    "dev": "webpack --watch --mode development",
    "build": "npm run lint && webpack",
    "package": "npm run build && npm run zip",
    "zip": "cd dist && zip -r ../group-tabs-by-domain-v$(node -p \"require('../package.json').version\").zip . && cd ..",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
