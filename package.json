{
  "name": "group-tabs-by-domain",
  "version": "1.2.0",
  "description": "Chrome extension that automatically groups browser tabs by domain, with optional single-tab grouping",
  "author": "Viking Jonsson",
  "license": "MIT",
  "keywords": [
    "chrome-extension",
    "tabs",
    "grouping",
    "domain",
    "productivity"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS='--import tsx' webpack --watch --mode development",
    "build": "npm run lint && NODE_OPTIONS='--import tsx' webpack",
    "package": "npm run build && npm run zip",
    "zip": "cd dist && zip -r ../group-tabs-by-domain-v$(node -p \"require('../package.json').version\").zip . && cd ..",
    "sync-version": "node -e \"const fs=require('fs');const m=JSON.parse(fs.readFileSync('manifest.json'));m.version=require('./package.json').version;fs.writeFileSync('manifest.json',JSON.stringify(m,null,2)+'\\n')\"",
    "prepackage": "npm run sync-version",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
